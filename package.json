{
  "name": "electron-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "build-win": "vite build && electron-builder --win",
    "build-mac": "vite build && electron-builder --mac",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.demo.electron",
    "productName": "ElectronApp",
    "files": [
      "package.json",
      "dist",
      "dist-electron"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vue-tsc": "^3.3.5"
  }
}
